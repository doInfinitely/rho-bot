# Server configuration
RHOBOT_SECRET_KEY=change-me-use-openssl-rand-hex-32
RHOBOT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rhobot
RHOBOT_DEBUG=false

# Model — remote inference (production: Railway → Modal)
RHOBOT_MODEL_INFERENCE_URL=

# Model — local inference (dev with GPU, or self-hosted)
RHOBOT_MODEL_PATH=
RHOBOT_MODEL_DEVICE=
RHOBOT_MODEL_ENCRYPTION_KEY=

# Stripe
RHOBOT_STRIPE_SECRET_KEY=sk_test_...
RHOBOT_STRIPE_WEBHOOK_SECRET=whsec_...
RHOBOT_STRIPE_PRO_PRICE_ID=price_...
RHOBOT_STRIPE_TEAM_PRICE_ID=price_...
RHOBOT_FRONTEND_URL=http://localhost:3000
